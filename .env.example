# 로컬 테스트용 환경변수 예시. 실제 값을 채운 뒤 파일명을 .env 로 복사해 사용하세요.
# (.env 와 키 JSON 파일은 .gitignore 로 저장소에서 제외됩니다 — 절대 커밋 금지)

# [방법 1·로컬 권장] 다운로드한 서비스계정 키 .json "파일 경로"만 적기
GOOGLE_SERVICE_ACCOUNT_FILE=key.json

# [방법 2·GitHub Actions용] 키 JSON "전체 내용"을 한 줄 문자열로. (둘 중 하나만)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# 대상 캘린더 ID. 여러 개면 쉼표로 이어 한 줄로 (Google 캘린더 설정 > 캘린더 통합 > 캘린더 ID)
GOOGLE_CALENDAR_ID=aaa@group.calendar.google.com,bbb@group.calendar.google.com

# [선택] 다른 구글 계정의 캘린더 — 그 계정의 서비스계정 키 + 캘린더ID를 _2 로 추가
# (서비스계정은 자기에게 공유된 캘린더만 읽으므로 계정마다 키가 따로 필요)
# GOOGLE_SERVICE_ACCOUNT_FILE_2=key2.json
# GOOGLE_CALENDAR_ID_2=ccc@group.calendar.google.com,ddd@group.calendar.google.com

# Discord 채널 웹훅 URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy
